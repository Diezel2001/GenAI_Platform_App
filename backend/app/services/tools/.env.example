# =============================================================
# .env.example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================


# =============================================================
# EMAIL TOOLS (email_tools.py)
# Used by: send_email, read_email, list_emails
# =============================================================

EMAIL_ADDRESS=you@example.com
EMAIL_PASSWORD=your_app_password_here

# SMTP (outgoing mail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# IMAP (incoming mail)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Gmail users: generate an App Password at
# https://myaccount.google.com/apppasswords
# (requires 2FA to be enabled)


# =============================================================
# DATABASE / SQL TOOLS (sql_tools.py)
# Used by: execute_sql, list_tables, describe_table
# =============================================================

# Engine: sqlite | postgres | mysql
DB_ENGINE=sqlite

# SQLite only — path to the .db file
DB_PATH=agent.db

# PostgreSQL / MySQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mydb
DB_USER=myuser
DB_PASSWORD=mypassword

# PostgreSQL dependency: pip install psycopg2-binary
# MySQL dependency:      pip install mysql-connector-python


# =============================================================
# CALENDAR TOOLS (calendar_tools.py)
# Used by: list_events, create_event, update_event,
#          delete_event, check_availability
# =============================================================

# Backend: local | google | caldav
CALENDAR_BACKEND=local

# Local backend — JSON file used for testing
LOCAL_CALENDAR_PATH=calendar.json

# Google Calendar backend (uncomment when using google)
# GOOGLE_CREDENTIALS_PATH=credentials.json
# GOOGLE_CALENDAR_ID=primary
# Dependency: pip install google-api-python-client google-auth

# CalDAV backend (uncomment when using caldav)
# CALDAV_URL=https://caldav.example.com/calendars/user/
# CALDAV_USER=your_username
# CALDAV_PASSWORD=your_password
# Dependency: pip install caldav


# =============================================================
# WEB TOOLS (web_tools.py)
# Used by: web_search, web_fetch
# No credentials required — uses DuckDuckGo HTML interface.
#
# For production, replace with a proper Search API:
# =============================================================

# SerpAPI (optional upgrade for web_search)
# SERPAPI_KEY=your_serpapi_key_here
# Dependency: pip install google-search-results

# Brave Search API (optional upgrade for web_search)
# BRAVE_SEARCH_API_KEY=your_brave_key_here


# =============================================================
# HTTP TOOLS (http_tools.py)
# Used by: http_request
# No global credentials — auth is passed per-request via headers.
# =============================================================


# =============================================================
# FILE TOOLS (file_tools.py)
# Used by: read_file, write_file, list_directory
# No credentials required.
# =============================================================


# =============================================================
# PYTHON EXECUTION TOOLS (python_tools.py)
# Used by: execute_python
# No credentials required.
#
# WARNING: execute_python runs code in-process.
# For production, set up a sandboxed executor (Docker, gVisor, etc.)
# and replace the implementation in python_tools.py.
# =============================================================
